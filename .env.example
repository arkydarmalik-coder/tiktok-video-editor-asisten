# Template env file - copy to .env and fill in real values locally.
# DO NOT commit .env (gitignored).

# --- 9router LLM (OpenAI-compatible endpoint) ---
# Get base URL + key from your 9router dashboard.
# Default model below is "utama"; switch as needed.
NINEROUTER_BASE_URL=https://arkydar-9router.hf.space/v1
NINEROUTER_API_KEY=replace_me
NINEROUTER_MODEL=utama

# --- Telegram bot ---
# Create a bot via @BotFather, then send /start to the bot to activate.
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me

# --- Cloudflare Worker (keep-alive ping target) ---
# Deploy a tiny Worker that responds 200 to GET /ping,
# then paste its URL here. The app will ping it on startup.
CLOUDFLARE_WORKER_URL=

# --- App tunables ---
WORK_DIR=/tmp/tvea_work
OUTPUT_DIR=/tmp/tvea_output
MAX_VIDEO_DURATION_S=120
DEFAULT_TRANSITION=whip_pan_right
